<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutPrincipal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/FondSoleil">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="10dp">
        <TextView
            android:id="@+id/txtVies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vies : 3"
            android:textSize="20sp"
            android:textColor="#FFFFFF"/>
        <TextView
            android:id="@+id/txtNourriture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nourriture : 3"
            android:textSize="20sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <TextClock
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_margin="10dp"
        android:textSize="24sp"
        android:textColor="#FFFFFF"/>

    <ImageView
        android:id="@+id/mooseMan"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_centerInParent="true"
        android:src="@drawable/MooseMan" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:padding="20dp">
        <ImageButton
            android:id="@+id/btnCuisine"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher_round"
            android:layout_marginRight="40dp"/>
        <ImageButton
            android:id="@+id/btnCalcul"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher_round" />
    </LinearLayout>
</RelativeLayout>